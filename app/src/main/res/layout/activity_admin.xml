<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EDF4F4"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/admin_title"
            android:textColor="#12363C"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText android:id="@+id/userNameInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:hint="@string/admin_username" android:padding="14dp" />
        <EditText android:id="@+id/passwordInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/auth_password" android:inputType="textPassword" android:padding="14dp" />
        <Button android:id="@+id/addUserButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/button_primary" android:text="@string/admin_add_user" android:textColor="#FFFFFF" />
        <Button android:id="@+id/deleteUserButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/button_secondary" android:text="@string/admin_delete_user" android:textColor="#FFFFFF" />
        <Button android:id="@+id/resetPasswordButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/button_secondary" android:text="@string/admin_reset_password" android:textColor="#FFFFFF" />

        <EditText android:id="@+id/pinLabelInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:hint="@string/admin_label" android:padding="14dp" />
        <EditText android:id="@+id/latitudeInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/admin_latitude" android:inputType="numberDecimal|numberSigned" android:padding="14dp" />
        <EditText android:id="@+id/longitudeInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/admin_longitude" android:inputType="numberDecimal|numberSigned" android:padding="14dp" />
        <EditText android:id="@+id/radiusInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/admin_radius" android:inputType="numberDecimal" android:padding="14dp" />
        <Button android:id="@+id/addPinButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/button_primary" android:text="@string/admin_add_pin" android:textColor="#FFFFFF" />
        <Button android:id="@+id/removePinButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/button_secondary" android:text="@string/admin_remove_pin" android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/usersListText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#18333A"
            tools:text="@string/admin_users" />
    </LinearLayout>
</ScrollView>
